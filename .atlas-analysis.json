  "keyFeatures": [
    "Phone authentication with Firebase Auth",
    "Real-time order tracking with Mapbox",
    "In-app messaging between buyers and drivers",
    "SQLite local database for order history",
    "Push notifications via Firebase Cloud Messaging",
    "Multiple payment methods (mobile money and cash)",
    "Live driver location updates",
    "Route visualization with distance and duration"
  ],
  "publicApiSurface": [
    "LoginPage - Phone and email authentication",
    "HomePage - Main order management interface",
    "MapPage - Real-time tracking and route visualization",
    "Chat - In-app messaging system",
    "SettingsPage - User preferences and account management",
    "CreditCardPage - Payment method configuration",
    "Firebase Realtime Database - Driver location updates",
    "Cloud Firestore - Chat messages and user data",
    "Mapbox Directions API - Route calculation and navigation"
  ]
